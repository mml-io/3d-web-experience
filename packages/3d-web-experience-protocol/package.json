{
  "name": "@mml-io/3d-web-experience-protocol",
  "version": "0.26.1",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mml-io/3d-web-experience.git",
    "directory": "packages/3d-web-experience-protocol"
  },
  "main": "./build/index.js",
  "types": "./build/index.d.ts",
  "type": "module",
  "files": [
    "/build"
  ],
  "scripts": {
    "depcheck": "depcheck --quiet",
    "build": "tsx ./build.ts --build",
    "iterate": "tsx ./build.ts --watch",
    "type-check": "tsc --noEmit",
    "lint": "eslint \"./{src,test}/**/*.{js,jsx,ts,tsx}\" --max-warnings 0",
    "lint-fix": "eslint \"./{src,test}/**/*.{js,jsx,ts,tsx}\" --fix",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest"
  },
  "devDependencies": {
    "@jest/globals": "29.7.0",
    "@types/node": "^20.0.0",
    "cross-env": "^7.0.3",
    "jest": "^29.7.0",
    "jest-junit": "16.0.0",
    "ts-jest": "^29.1.2"
  }
}
