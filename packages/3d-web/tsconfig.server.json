{
  "compilerOptions": {
    "noImplicitAny": true,
    "module": "es2022",
    "target": "es2022",
    "lib": ["es2022"],
    "esModuleInterop": true,
    "sourceMap": true,
    "allowJs": true,
    "strictNullChecks": true,
    "allowSyntheticDefaultImports": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "downlevelIteration": true,
    "outDir": "./build",
    "incremental": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*", "test/**/*", "./build.ts", "./jest.config.ts"],
  "exclude": ["src/client/**/*", "**/build/*"]
}
